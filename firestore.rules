rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Helper: Check if the requesting user is a super-admin
    function isSuperAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'super-admin';
    }

    // Helper: Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Admins collection - super-admins can read/write, admins can only read
    // New admins can only be created with role 'admin' (no new super-admins)
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create: if isSuperAdmin() && request.resource.data.role == 'admin';
      allow update: if isSuperAdmin() && request.resource.data.role == 'admin';
      allow delete: if isSuperAdmin();
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAdmin() || isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId)
                    || (isAuthenticated()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['averageRating']));
      allow create, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // Posts collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() ||
                              (isAuthenticated() && resource.data.artistId == request.auth.uid);
    }

    // Reports collection
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Ratings collection
    match /ratings/{ratingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() ||
                              (isAuthenticated() && resource.data.customerId == request.auth.uid);
    }

    // Subscriptions collection - admins can manage, artists can read and subscribe
    match /subscriptions/{subscriptionId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == subscriptionId);
      allow create, update: if isAdmin() || (isAuthenticated() && request.auth.uid == subscriptionId);
      allow delete: if isSuperAdmin();
    }

    // Audit logs - only admins can read, only admins can create, no update/delete (immutable)
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // Notifications collection - users manage their own, admins can read all
    match /notifications/{notificationId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Orders collection - admins full access, customers read own, artists read/update their orders
    match /orders/{orderId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.customerId == request.auth.uid) ||
        (isAuthenticated() && resource.data.artistId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.artistId == request.auth.uid);
      allow delete: if isSuperAdmin();
    }

    // Payments collection - admins read/update, users read own, no delete (immutable for audit)
    match /payments/{paymentId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Payouts collection - admins manage, artists read own and create (withdrawal), no delete
    match /payouts/{payoutId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.artistId == request.auth.uid);
      allow create: if isAdmin() || isAuthenticated();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Cart subcollection - users manage their own cart, admins can read
    match /users/{userId}/cart/{cartItemId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    // Wallets collection - virtual wallet for artists
    // Artists can read/create/update their own wallet (for earnings credit + withdrawal debit)
    match /wallets/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if false;
    }

    // Conversations collection - participants can read/create/update, admins can read
    match /conversations/{conversationId} {
      allow get: if isAuthenticated();
      allow list: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();

      // Messages subcollection
      match /messages/{messageId} {
        allow read, create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }
  }
}
